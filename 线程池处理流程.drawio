<mxfile host="65bd71144e">
    <diagram id="threadpool-flow" name="线程池处理流程">
        <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" background="#1e1e1e" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- 标题 -->
                <mxCell id="title" value="&lt;b&gt;ThreadPoolExecutor 处理流程&lt;/b&gt;" style="text;html=1;fontSize=20;fontColor=#ffffff;align=center;" vertex="1" parent="1">
                    <mxGeometry x="350" y="20" width="300" height="35" as="geometry"/>
                </mxCell>

                <!-- 任务提交 -->
                <mxCell id="task" value="提交任务&lt;br&gt;execute()" style="shape=ellipse;whiteSpace=wrap;html=1;fillColor=#4a90d9;strokeColor=#6cb4ee;fontSize=13;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
                    <mxGeometry x="420" y="70" width="160" height="60" as="geometry"/>
                </mxCell>

                <!-- 判断：核心线程是否满 -->
                <mxCell id="d1" value="核心线程&lt;br&gt;是否满?&lt;br&gt;(4/4)" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#f5a623;strokeColor=#f7c948;fontSize=11;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="430" y="170" width="140" height="90" as="geometry"/>
                </mxCell>

                <!-- 队列是否满 -->
                <mxCell id="d2" value="队列&lt;br&gt;是否满?&lt;br&gt;(100/100)" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#f5a623;strokeColor=#f7c948;fontSize=11;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="700" y="170" width="140" height="90" as="geometry"/>
                </mxCell>

                <!-- 核心线程未满 -->
                <mxCell id="core" value="创建核心线程&lt;br&gt;执行任务" style="shape=process;whiteSpace=wrap;html=1;fillColor=#7ed321;strokeColor=#a8e06c;fontSize=12;fontStyle=1;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="150" y="180" width="160" height="60" as="geometry"/>
                </mxCell>

                <!-- 队列未满 -->
                <mxCell id="queue" value="加入等待队列&lt;br&gt;ArrayBlockingQueue(100)" style="shape=process;whiteSpace=wrap;html=1;fillColor=#4a90d9;strokeColor=#6cb4ee;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
                    <mxGeometry x="700" y="310" width="180" height="60" as="geometry"/>
                </mxCell>

                <!-- 判断max -->
                <mxCell id="d3" value="线程数&lt;br&gt;是否达到&lt;br&gt;max? (4)" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#f5a623;strokeColor=#f7c948;fontSize=11;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="920" y="310" width="130" height="90" as="geometry"/>
                </mxCell>

                <!-- 非核心线程 -->
                <mxCell id="noncore" value="创建非核心线程&lt;br&gt;执行任务" style="shape=process;whiteSpace=wrap;html=1;fillColor=#bd10e0;strokeColor=#d45cf7;fontSize=12;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
                    <mxGeometry x="900" y="440" width="160" height="60" as="geometry"/>
                </mxCell>

                <!-- 拒绝策略 -->
                <mxCell id="reject" value="执行拒绝策略&lt;br&gt;AbortPolicy&lt;br&gt;抛出 RejectedExecutionException" style="shape=process;whiteSpace=wrap;html=1;fillColor=#d0021b;strokeColor=#f77683;fontSize=11;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
                    <mxGeometry x="880" y="560" width="200" height="70" as="geometry"/>
                </mxCell>

                <!-- 标记失败 -->
                <mxCell id="fail" value="chart.status = &amp;quot;failed&amp;quot;&lt;br&gt;execMessage = &amp;quot;系统繁忙&amp;quot;" style="shape=process;whiteSpace=wrap;html=1;fillColor=#d0021b;strokeColor=#f77683;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
                    <mxGeometry x="880" y="670" width="200" height="55" as="geometry"/>
                </mxCell>

                <!-- 执行完成 -->
                <mxCell id="done" value="任务执行完成" style="shape=ellipse;whiteSpace=wrap;html=1;fillColor=#7ed321;strokeColor=#a8e06c;fontSize=12;fontStyle=1;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="170" y="310" width="120" height="50" as="geometry"/>
                </mxCell>

                <!-- 线程池示意 -->
                <mxCell id="pool_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6cb4ee;strokeWidth=2;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="400" width="800" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="pool_title" value="&lt;b&gt;ThreadPoolExecutor (core=4, max=4, queue=100)&lt;/b&gt;" style="text;html=1;fontSize=12;fontColor=#6cb4ee;align=left;" vertex="1" parent="1">
                    <mxGeometry x="50" y="405" width="350" height="20" as="geometry"/>
                </mxCell>

                <!-- 线程1-4 -->
                <mxCell id="t1" value="&lt;b&gt;Thread-1&lt;/b&gt;&lt;br&gt;chart-task-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7ed321;strokeColor=#a8e06c;fontSize=10;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="60" y="440" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="t2" value="&lt;b&gt;Thread-2&lt;/b&gt;&lt;br&gt;chart-task-2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7ed321;strokeColor=#a8e06c;fontSize=10;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="200" y="440" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="t3" value="&lt;b&gt;Thread-3&lt;/b&gt;&lt;br&gt;chart-task-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7ed321;strokeColor=#a8e06c;fontSize=10;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="340" y="440" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="t4" value="&lt;b&gt;Thread-4&lt;/b&gt;&lt;br&gt;chart-task-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7ed321;strokeColor=#a8e06c;fontSize=10;fontColor=#1e1e1e;" vertex="1" parent="1">
                    <mxGeometry x="480" y="440" width="120" height="50" as="geometry"/>
                </mxCell>

                <!-- 队列示意 -->
                <mxCell id="queue_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d2d;strokeColor=#666;strokeWidth=1;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="60" y="510" width="540" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="queue_label" value="等待队列 ArrayBlockingQueue (容量: 100)" style="text;html=1;fontSize=10;fontColor=#999;align=center;" vertex="1" parent="1">
                    <mxGeometry x="150" y="515" width="300" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="queue_items" value="[ Task1 ] [ Task2 ] [ Task3 ] ... [ TaskN ]" style="text;html=1;fontSize=11;fontColor=#ccc;align=center;" vertex="1" parent="1">
                    <mxGeometry x="100" y="535" width="400" height="20" as="geometry"/>
                </mxCell>

                <!-- 连接线 -->
                <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;fontColor=#cccccc;strokeColor=#999;" edge="1" source="task" target="d1" parent="1"/>
                <mxCell id="e2" value="否" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=12;fontColor=#7ed321;strokeColor=#7ed321;" edge="1" source="d1" target="core" parent="1"/>
                <mxCell id="e3" value="是" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=12;fontColor=#d0021b;strokeColor=#d0021b;" edge="1" source="d1" target="d2" parent="1"/>
                <mxCell id="e4" value="否" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=12;fontColor=#7ed321;strokeColor=#7ed321;" edge="1" source="d2" target="queue" parent="1"/>
                <mxCell id="e5" value="是" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=12;fontColor=#d0021b;strokeColor=#d0021b;" edge="1" source="d2" target="d3" parent="1"/>
                <mxCell id="e6" value="否" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=12;fontColor=#7ed321;strokeColor=#7ed321;" edge="1" source="d3" target="noncore" parent="1"/>
                <mxCell id="e7" value="是" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=12;fontColor=#d0021b;strokeColor=#d0021b;" edge="1" source="d3" target="reject" parent="1"/>
                <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;fontColor=#cccccc;strokeColor=#999;" edge="1" source="reject" target="fail" parent="1"/>
                <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;fontColor=#cccccc;strokeColor=#999;" edge="1" source="core" target="done" parent="1"/>

                <!-- 图例 -->
                <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d2d;strokeColor=#666;" vertex="1" parent="1">
                    <mxGeometry x="40" y="620" width="220" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="legend_title" value="&lt;b&gt;图例&lt;/b&gt;" style="text;html=1;fontSize=12;fontColor=#ffffff;align=left;" vertex="1" parent="1">
                    <mxGeometry x="55" y="625" width="60" height="20" as="geometry"/>
                </mxCell>

                <mxCell id="leg1" value="" style="shape=ellipse;fillColor=#7ed321;strokeColor=#a8e06c;" vertex="1" parent="1">
                    <mxGeometry x="55" y="655" width="16" height="16" as="geometry"/>
                </mxCell>
                <mxCell id="leg1t" value="开始 / 结束 / 成功" style="text;fontSize=10;fontColor=#cccccc;" vertex="1" parent="1">
                    <mxGeometry x="80" y="653" width="130" height="18" as="geometry"/>
                </mxCell>

                <mxCell id="leg2" value="" style="shape=rhombus;fillColor=#f5a623;strokeColor=#f7c948;" vertex="1" parent="1">
                    <mxGeometry x="55" y="683" width="16" height="16" as="geometry"/>
