                <mxCell id="leg2t" value="判断条件" style="text;fontSize=10;fontColor=#cccccc;" vertex="1" parent="1">
                    <mxGeometry x="80" y="681" width="130" height="18" as="geometry"/>
                </mxCell>

                <mxCell id="leg3" value="" style="shape=process;fillColor=#bd10e0;strokeColor=#d45cf7;" vertex="1" parent="1">
                    <mxGeometry x="55" y="711" width="16" height="16" as="geometry"/>
                </mxCell>
                <mxCell id="leg3t" value="非核心线程" style="text;fontSize=10;fontColor=#cccccc;" vertex="1" parent="1">
                    <mxGeometry x="80" y="709" width="130" height="18" as="geometry"/>
                </mxCell>

                <mxCell id="leg4" value="" style="shape=process;fillColor=#d0021b;strokeColor=#f77683;" vertex="1" parent="1">
                    <mxGeometry x="55" y="739" width="16" height="16" as="geometry"/>
                </mxCell>
                <mxCell id="leg4t" value="拒绝 / 失败" style="text;fontSize=10;fontColor=#cccccc;" vertex="1" parent="1">
