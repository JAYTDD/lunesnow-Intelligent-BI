    <diagram id="HxzskmOlAVHwfGZFeNn8" name="图表异步生成流程">
        <mxGraphModel dx="1422" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
