                <!-- ==================== 提交阶段 ==================== -->
                <mxCell id="title1" value="&lt;b&gt;① 提交阶段&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#1a1a2e;align=center;" vertex="1" parent="1">
                    <mxGeometry x="60" y="20" width="180" height="35" as="geometry"/>
                </mxCell>

                <mxCell id="start" value="用户点击&amp;quot;生成图表&amp;quot;" style="shape=ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="80" y="70" width="200" height="60" as="geometry"/>
                </mxCell>

                <mxCell id="step1" value="参数校验&lt;br&gt;name, goal 非空&lt;br&gt;文件 ≤ 2MB&lt;br&gt;后缀 .xlsx/.xls" style="shape=process;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="70" y="180" width="220" height="70" as="geometry"/>
                </mxCell>

                <mxCell id="step2" value="Excel → CSV&lt;br&gt;ExcelUtils.excelToCsv()" style="shape=process;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="70" y="300" width="220" height="60" as="geometry"/>
                </mxCell>

                <mxCell id="step3" value="保存 Chart 到 chart 表&lt;br&gt;status = &amp;quot;waiting&amp;quot;&lt;br&gt;chartData = CSV" style="shape=process;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="70" y="410" width="220" height="70" as="geometry"/>
                </mxCell>

                <mxCell id="step4" value="创建动态表 chart_{id}&lt;br&gt;chartDataService.createTableFromCsv()" style="shape=process;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="70" y="530" width="220" height="60" as="geometry"/>
                </mxCell>

                <mxCell id="step5" value="提交到线程池&lt;br&gt;chartTaskExecutor.execute()" style="shape=process;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="70" y="640" width="220" height="60" as="geometry"/>
                </mxCell>

                <mxCell id="step6" value="立即返回 { chartId }" style="shape=ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="80" y="750" width="200" height="55" as="geometry"/>
